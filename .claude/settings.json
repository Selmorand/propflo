      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git restore:*)",
      "Bash(git remote:*)",
      "Bash(git fetch:*)",
      "Bash(git ls-remote:*)",
      "Bash(git config:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ],
    "defaultMode": "acceptEdits"
  }
